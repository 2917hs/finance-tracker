<Window x:Class="FinanceTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FinanceTracker.ViewModels"
        xmlns:views="clr-namespace:FinanceTracker.Views"
        mc:Ignorable="d"

        Title="Finance Tracker"
        Height="780" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource PrimaryBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TransactionListViewModel}">
            <views:TransactionListView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Navigation sidebar — Width animated on toggle -->
            <ColumnDefinition x:Name="NavColumn" Width="220"/>
            <!-- Main content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- === SIDEBAR NAVIGATION === -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App header -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,16"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="28"/>
                        <TextBlock Text="Finance Tracker"
                                   Style="{StaticResource HeadingMedium}"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="Personal budget manager"
                                   Style="{StaticResource CaptionText}"/>
                    </StackPanel>
                </Border>

                <!-- Inside the sidebar StackPanel -->
                <StackPanel DockPanel.Dock="Top" Margin="12,16,12,0">
                    <Button Content="📊  Dashboard"
            Style="{StaticResource PrimaryButton}"
            Command="{Binding NavigateToDashboardCommand}"
            Margin="0,0,0,8"
            HorizontalContentAlignment="Left"/>
                    <Button Content="💳  Transactions"
            Style="{StaticResource PrimaryButton}"
            Command="{Binding NavigateToTransactionsCommand}"
            HorizontalContentAlignment="Left"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- === MAIN CONTENT === -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Top bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,16">
                <TextBlock Text="{Binding CurrentPageTitle}"
                           Style="{StaticResource HeadingMedium}"/>
            </Border>

            <!-- ContentControl renders the DataTemplate for CurrentView -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"
                            Margin="24"/>
        </Grid>
    </Grid>
</Window>